{
  "name": "frontend",
  "version": "1.0.0",
  "description": "Frontend Rust testing for Mori infinite canvas",
  "main": "index.js",
  "scripts": {
    "test": "wasm-pack test --headless --chrome",
    "test:headed": "wasm-pack test --chrome",
    "test:firefox": "wasm-pack test --headless --firefox",
    "test:safari": "wasm-pack test --headless --safari",
    "test:all": "wasm-pack test --headless --chrome && wasm-pack test --headless --firefox",
    "cargo:test": "cargo test",
    "cargo:test:watch": "cargo watch -x test",
    "build": "trunk build",
    "build:release": "trunk build --release",
    "serve": "trunk serve",
    "serve:open": "trunk serve --open"
  },
  "keywords": [
    "rust",
    "wasm",
    "testing",
    "canvas",
    "yew"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "wasm-pack": "^0.12.1"
  }
}
